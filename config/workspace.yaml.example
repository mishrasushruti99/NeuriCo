# Workspace Configuration
# Copy this file to workspace.yaml to customize settings
# (workspace.yaml is gitignored, so your local changes won't be pushed)

# Workspace directory configuration
workspace:
  # Parent directory for all research workspaces
  # Can be:
  # - Absolute path: /home/user/research-workspaces
  # - Relative to neurico root: workspace
  # - Environment variable: ${NEURICO_WORKSPACE}
  #
  # Default: workspaces (relative to project root, already gitignored)
  parent_dir: "workspaces"

  # Whether to create workspace parent directory if it doesn't exist
  auto_create: true

  # Default permissions for created workspace directories (octal)
  permissions: 0o755

# Retry configuration for API calls and subprocess launches
retry:
  max_attempts: 3
  backoff_factor: 2.0
  initial_delay: 1.0
  max_delay: 60.0
